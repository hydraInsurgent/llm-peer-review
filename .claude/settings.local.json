{
  "defaultMode": "acceptEdits",
  "permissions": {
    "allow": [
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git rm *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git config *)",
      "Bash(git remote add *)",
      "Bash(git remote set-url *)",
      "Bash(git check-ignore *)",
      "Bash(git worktree *)",
      "Bash(git rev-parse *)",

      "Bash(gh repo create *)",
      "Bash(gh repo view *)",
      "Bash(gh repo edit *)",
      "Bash(gh repo clone *)",
      "Bash(gh auth status *)",
      "Bash(gh issue create *)",
      "Bash(gh issue view *)",
      "Bash(gh issue close *)",
      "Bash(gh issue list *)",
      "Bash(gh issue reopen *)",
      "Bash(gh label list *)",
      "Bash(gh label create *)",
      "Bash(gh pr create *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh api *)",
      "Bash(gh release list *)",

      "Bash(npm install *)",
      "Bash(npm uninstall *)",

      "Bash(node scripts/ask-gpt.js *)",
      "Bash(node scripts/ask-gemini.js *)",
      "Bash(node scripts/browse.js *)",

      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",

      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebSearch",

      "Bash(cp *)",

      "Bash(ls *)",
      "Bash(diff *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(cat *)"
    ],
    "additionalDirectories": [
      "/tmp"
    ]
  }
}
